[
  {"add_schema":{"name":"population","fields":[["bloc","symbol"],["count","int"]],"key":1}},
  {"add_schema":{"name":"approval","fields":[["bloc","symbol"],["value","float"]],"key":1}},
  {"add_schema":{"name":"treasury","fields":[["id","symbol"],["amount","float"]],"key":1}},
  {"add_schema":{"name":"param","fields":[["name","symbol"],["value","float"]],"key":1}},
  {"add_fact":{"schema":"population","values":["north",1000]}},
  {"add_fact":{"schema":"population","values":["south",800]}},
  {"add_fact":{"schema":"approval","values":["north",0.6]}},
  {"add_fact":{"schema":"approval","values":["south",0.5]}},
  {"add_fact":{"schema":"treasury","values":["main",0]}},
  {"add_fact":{"schema":"param","values":["poll_tax_rate",0.1]}},
  {"add_fact":{"schema":"param","values":["tax_resentment",0.5]}},
  {"add_rule":{"name":"collect_poll_tax","on":"tick.quarter","when":{"lit":true},"do":[{"foreach":{"schema":"population","bind":"p","do":[{"update":{"schema":"treasury","key":[{"lit":"main"}],"field":"amount","op":"add","value":{"bin":["mul",{"field":["p","count"]},{"param":"poll_tax_rate"}]}}},{"update":{"schema":"approval","key":[{"field":["p","bloc"]}],"field":"value","op":"add","value":{"bin":["mul",{"lit":-0.02},{"param":"tax_resentment"}]}}}]}}]}},

  {"add_schema":{"name":"seat","fields":[["holder","symbol"],["chamber","symbol"]],"key":2}},
  {"add_fact":{"schema":"seat","values":["baron","lower"]}},

  {"add_meta":{"name":"amend_statute","layer":"organic","governs":"statute",
    "allow":{"bin":["eq",{"field":["diff","via"]},{"lit":"pass_statute"}]}}},
  {"add_meta":{"name":"amend_organic","layer":"constitution","governs":"organic","allow":{"lit":true}}},

  {"add_procedure":{"name":"pass_statute","layer":"organic","steps":[
    {"name":"introduce","requires":{"exists":{"schema":"seat","key":[{"field":["instance","by"]},{"lit":"lower"}]}}},
    {"name":"floor_vote","requires":{"bin":["gt",{"lookup":{"schema":"approval","key":[{"lit":"north"}],"field":"value"}},{"lit":0.4}]}},
    {"name":"assent","requires":{"bin":["gt",{"lookup":{"schema":"treasury","key":[{"lit":"main"}],"field":"amount"}},{"lit":-1.0}]}}
  ]}}
]
